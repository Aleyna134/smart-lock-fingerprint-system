# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.cpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.hpp text eol=lf
*.ino text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.ini text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Denoting files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.bin binary
*.pdf binary
