generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  password    String
  role        String        @default("USER")
  enrollment_status String  @default("ENROLLED")
  enrolled_at DateTime      @default(now())
  logs        Log[]
  deviceTokens DeviceToken[]
  hardwareCommands HardwareCommand[]
}

model Log {
  id         Int      @id @default(autoincrement())
  success    Boolean
  status     String
  time       DateTime @default(now())
  fail_count Int      @default(0)
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id])
  alert      Alert?
}

model Alert {
  id         Int            @id @default(autoincrement())
  type       String
  severity   String
  title      String
  detail     String
  status     String         @default("UNREAD")
  log_id     Int?           @unique
  log        Log?           @relation(fields: [log_id], references: [id])
  created_at DateTime       @default(now())
  deliveries PushDelivery[]
}

model DeviceToken {
  id         Int            @id @default(autoincrement())
  token      String         @unique
  user_id    Int?
  user       User?          @relation(fields: [user_id], references: [id])
  platform   String         @default("ios")
  is_active  Boolean        @default(true)
  created_at DateTime       @default(now())
  deliveries PushDelivery[]
}

model PushDelivery {
  id              Int      @id @default(autoincrement())
  alert_id        Int
  device_token_id Int
  status          String   @default("PENDING")
  attempts        Int      @default(0)
  last_error      String?
  sent_at         DateTime?
  next_retry_at   DateTime @default(now())
  alert           Alert       @relation(fields: [alert_id], references: [id])
  deviceToken     DeviceToken @relation(fields: [device_token_id], references: [id])

  @@unique([alert_id, device_token_id])
}

model HardwareCommand {
  id           Int       @id @default(autoincrement())
  type         String
  status       String    @default("PENDING")
  device_id    String    @default("lock-1")
  user_id      Int?
  user         User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)
  attempts     Int       @default(0)
  error        String?
  created_at   DateTime  @default(now())
  claimed_at   DateTime?
  completed_at DateTime?

  @@index([device_id, status])
  @@index([status, type, created_at])
}

model SystemState {
  id               Int      @id
  lock_status      String   @default("Locked")
  last_state_event String?
  updated_at       DateTime @updatedAt
}
