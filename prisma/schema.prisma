generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// YENİ TABLOMUZ: Kayıtlı Kullanıcılar
model User {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique  // Mail adresi benzersiz olmalı
  password    String            // Şifre alanı
  role        String   @default("USER") // "ADMIN" veya "USER"
  enrolled_at DateTime @default(now())
  logs        Log[]
}

// GÜNCELLENEN TABLOMUZ: Loglar
model Log {
  id         Int      @id @default(autoincrement())
  success    Boolean
  status     String
  time       DateTime @default(now())
  fail_count Int      @default(0)
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id])
}